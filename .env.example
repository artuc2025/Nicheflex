# Supabase — get from supabase.com → Project Settings → API
NUXT_PUBLIC_SUPABASE_URL=your-project-url
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key

# YouTube Data API v3 — get from console.cloud.google.com
NUXT_YOUTUBE_API_KEY=your-youtube-api-key

# Anthropic API — get from console.anthropic.com
NUXT_ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NUXT_PUBLIC_SITE_URL=http://localhost:3000
